    "version": "0.2.0",
    "configurations": [
        {
            "name": "stack_overflow_api",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=stack_overflow_api"
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}/stack_overflow_api",
            "envFile": "${workspaceFolder}/stack_overflow_api/.env",
            "env": {
                "RUST_LOG": "stack_overflow_api=debug,tower_http=debug,sqlx=warn"
            }
        },
    ]
}